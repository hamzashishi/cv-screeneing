# ============= Django Settings =============
DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-random-secret
SECRET_KEY=replace-with-a-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============= Database Settings =============
# Use SQLite for local development. For container deployment, use DATABASE_URL in production.
DATABASE_URL=sqlite:///db.sqlite3
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306

# ============= JWT Settings =============
JWT_SECRET_KEY=replace-with-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DELTA=3600

# ============= CORS Settings =============
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============= Email Configuration (Gmail) =============
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ============= SSL/Security Settings =============
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ============= File Upload Settings =============
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx

# ============= NLP Settings =============
SPACY_MODEL=en_core_web_sm

# ============= Redis/Celery (Optional) =============
REDIS_URL=redis://localhost:6379/0
