# ============= Django Settings =============
DEBUG=False
DJANGO_SECRET_KEY=your-production-secret-key
SECRET_KEY=your-production-secret-key
ALLOWED_HOSTS=your-domain.com,api.your-domain.com,backend
CSRF_TRUSTED_ORIGINS=https://cv-screening-ten.vercel.app,https://your-domain.com

# ============= Database Settings =============
# Container deployment uses SQLite by default; set DATABASE_URL to a PostgreSQL URL only if you switch databases.
DATABASE_URL=sqlite:///db.sqlite3

# Optional legacy DB settings (not required with DATABASE_URL)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# ============= JWT Settings =============
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DELTA=3600

# ============= CORS Settings =============
CORS_ALLOWED_ORIGINS=https://cv-screening-ten.vercel.app,https://your-domain.com

# ============= Email Configuration =============
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ============= SSL/Security Settings =============
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ============= File Upload Settings =============
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx

# ============= NLP Settings =============
SPACY_MODEL=en_core_web_sm

# ============= Redis/Celery (Optional) =============
REDIS_URL=redis://localhost:6379/0
