# ============= Django Settings =============
DEBUG=False
# DigitalOcean App Platform uses DJANGO_SECRET_KEY, but SECRET_KEY will also work for local testing.
DJANGO_SECRET_KEY=your-very-long-random-secret-key-change-this-in-production
SECRET_KEY=your-very-long-random-secret-key-change-this-in-production
ALLOWED_HOSTS=your-app-name.ondigitalocean.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-app-name.ondigitalocean.app,https://yourdomain.com

# ============= Database Settings =============
# Option 1: DigitalOcean PostgreSQL (Recommended)
# DigitalOcean provides this automatically - just use DATABASE_URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Option 2: PythonAnywhere MySQL (Legacy)
DB_ENGINE=django.db.backends.mysql
DB_NAME=yourusername$default
DB_USER=yourusername
DB_PASSWORD=your-mysql-password
DB_HOST=yourusername.mysql.pythonanywhere-services.com
DB_PORT=3306

# ============= JWT Settings =============
JWT_SECRET_KEY=your-jwt-secret-key-must-be-very-long-and-random
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DELTA=3600

# ============= CORS Settings =============
CORS_ALLOWED_ORIGINS=https://your-app-name.ondigitalocean.app,https://yourdomain.com,https://your-vercel-frontend.vercel.app

# ============= Email Configuration (Gmail) =============
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ============= SSL/Security Settings =============
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ============= File Upload Settings =============
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx

# ============= NLP Settings =============
SPACY_MODEL=en_core_web_sm

# ============= Redis/Celery (Optional) =============
# Only if using Celery for async tasks
REDIS_URL=redis://localhost:6379/0
